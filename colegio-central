const prom = e => +((e.fis + e.mat + e.ing)/3).toFixed(2);

function notaClass(n){
  if(n >= 4.5) return 'alto';
  if(n >= 4.0) return 'medio';
  return 'bajo';
}

function notaLabel(n){
  if(n >= 4.5) return '⬆ Alto';
  if(n >= 4.0) return '→ Medio';
  return '⬇ Bajo';
}

function initials(name){
  return name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
}

const avatarColors = [
  '#10b981','#34d399','#fbbf24','#f87171','#a78bfa',
  '#fb923c','#38bdf8','#f472b6','#4ade80','#4f8ef7'
];

function avatarColor(name){
  let h = 0;
  for(let c of name) h = (h * 31 + c.charCodeAt(0)) & 0xffffffff;
  return avatarColors[Math.abs(h) % avatarColors.length];
}

function subjectLabel(s){
  const map={
    fis:'Física', mat:'Matemáticas', ing:'Inglés',
    esp:'Español', bio:'Biología', quim:'Química',
    hist:'Historia', geo:'Geografía', art:'Arte'
