              onblur="this.style.borderColor='transparent'"></td>
            <td><input class="edit-nota" type="number" step="0.1" min="0" max="5"
              value="${e.mat}" onchange="editNota(${idx},'mat',this)"
              onfocus="this.style.borderColor='rgba(16,185,129,0.5)'"
              onblur="this.style.borderColor='transparent'"></td>
            <td><input class="edit-nota" type="number" step="0.1" min="0" max="5"
              value="${e.ing}" onchange="editNota(${idx},'ing',this)"
              onfocus="this.style.borderColor='rgba(16,185,129,0.5)'"
              onblur="this.style.borderColor='transparent'"></td>
            <td>
              <div class="prom-bar">
                <span class="nota ${cls}" style="width:36px">${p}</span>
                <div class="mini-track"><div class="mini-fill" style="width:${(p/5)*100}%;background:${cls==='alto'?'var(--green)':cls==='medio'?'var(--yellow)':'var(--red)'}"></div></div>
              </div>
            </td>
            <td><span class="badge ${cls}">${notaLabel(p)}</span></td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>
    ${lista.length===0?`<div style="padding:30px;text-align:center;color:var(--muted)">Sin resultados para este filtro.</div>`:''}
  </div>`;
}

function editNota(idx, field, input){
  let val = parseFloat(input.value);
  if(isNaN(val)) val = 0;
  val = Math.min(5, Math.max(0, +val.toFixed(1)));
  input.value = val;
  data[grado].estudiantes[idx][field] = val;
  saveState();
  toast(`✅ Nota actualizada: ${val}`, 'success');
  input.closest('tr').classList.add('saved');
  setTimeout(()=>input.closest('tr').classList.remove('saved'), 700);
}

function setFilter(f){
  filterLevel = f;
  renderBoletines(document.getElementById('contentArea'), f, document.getElementById('searchInput').value);
}

function sortBy(col){
  if(sortCol===col) sortDir*=-1;
  else{ sortCol=col; sortDir=1; }
  renderBoletines(document.getElementById('contentArea'), filterLevel, document.getElementById('searchInput').value);
}

function exportCSV(){
  const d = data[grado];
  let csv = 'Nombre,Física,Matemáticas,Inglés,Promedio\n';
  d.estudiantes.forEach(e=>{
    csv += `${e.name},${e.fis},${e.mat},${e.ing},${prom(e)}\n`;
  });
  const blob = new Blob([csv],{type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `boletin_central_grado${grado}.csv`;
  a.click();
  toast('📥 CSV exportado correctamente', 'success');
}

/* ===================================================
   TAREAS
=================================================== */
function renderTareas(area){
  const d = data[grado];
  const pendientes = d.tareas.filter(t=>!t.done);
  const completadas = d.tareas.filter(t=>t.done);

  area.innerHTML = `
  <div class="section-header">
    <div class="section-title">Pendientes (${pendientes.length})</div>
  </div>
  <div class="tasks-grid" id="tasksGrid">
    ${d.tareas.map((t,i)=>taskCard(t,i)).join('')}
  </div>
  <button class="add-task-btn" onclick="openAddTask()">+ Agregar nueva tarea</button>
  ${completadas.length>0?`<div class="divider"></div><div class="section-header"><div class="section-title">Completadas (${completadas.length})</div></div>`:''}
  `;
  updateBadges();
}

function taskCard(t){
  const colors = {
    fis:'var(--accent)',mat:'var(--blue)',ing:'var(--purple)',
    esp:'#f472b6',bio:'var(--yellow)',quim:'#fb923c',
    hist:'var(--red)',geo:'#38bdf8',art:'#f472b6'
  };
  return `
  <div class="task-card ${t.subject} fade-up" id="task-${t.id}" style="${t.done?'opacity:0.45':''}">
    <div class="task-subject" style="color:${colors[t.subject]||'var(--muted)'}">${subjectLabel(t.subject)}</div>
    <div class="task-name">${t.name}</div>
    <div class="task-bottom">
      <div class="task-due">📅 ${t.due}</div>
      <div class="task-check ${t.done?'done':''}" onclick="toggleTask(${t.id})" title="${t.done?'Deshacer':'Completar'}">${t.done?'✓':''}</div>
    </div>
  </div>`;
}

function toggleTask(id){
  const t = data[grado].tareas.find(x=>x.id===id);
  if(!t) return;
  t.done = !t.done;
  saveState();
  toast(t.done?'✅ Tarea completada':'↩ Tarea marcada como pendiente', 'success');
  renderTareas(document.getElementById('contentArea'));
}

function openAddTask(){
  document.getElementById('modalTitle').textContent = '📘 Nueva Tarea';
  document.getElementById('modalBody').innerHTML = `
    <div class="form-group">
      <label class="form-label">Nombre de la tarea</label>
      <input type="text" class="form-input" id="taskName" placeholder="Ej: Taller de laboratorio">
    </div>
    <div class="form-group">
      <label class="form-label">Materia</label>
      <select class="form-select" id="taskSubject">
        <option value="fis">Física</option>
        <option value="mat">Matemáticas</option>
        <option value="ing">Inglés</option>
        <option value="esp">Español</option>
        <option value="bio">Biología</option>
        <option value="quim">Química</option>
        <option value="hist">Historia</option>
        <option value="geo">Geografía</option>
        <option value="art">Arte</option>
      </select>
    </div>
    <div class="form-group">
      <label class="form-label">Fecha de entrega</label>
      <input type="text" class="form-input" id="taskDue" placeholder="Ej: 30 abr">
    </div>
  `;
  document.getElementById('modalConfirm').onclick = addTask;
  document.getElementById('modal').classList.add('open');
}

function addTask(){
  const name = document.getElementById('taskName').value.trim();
  const subject = document.getElementById('taskSubject').value;
  const due = document.getElementById('taskDue').value.trim()||'Sin fecha';
  if(!name){ toast('⚠ Ingresa el nombre de la tarea', 'warn'); return; }
  data[grado].tareas.push({id:++taskNextId, name, subject, due, done:false});
  saveState();
  closeModal();
  toast('✅ Tarea agregada', 'success');
  renderTareas(document.getElementById('contentArea'));
}

/* ===================================================
   EVENTOS
=================================================== */
function renderEventos(area){
  const d = data[grado];
  area.innerHTML = `
  <div class="events-layout">
    <div class="panel fade-up">
      <div class="panel-header">
        <div class="panel-title">📅 Próximos Eventos</div>
        <button class="panel-action" onclick="openAddEvento()">+ Agregar</button>
      </div>
      <div id="eventList">
        ${d.eventos.map(ev=>`
          <div class="event-item">
            <div class="event-date-box">
              <div class="ev-day">${ev.day}</div>
              <div class="ev-mon">${ev.mon}</div>
            </div>
            <div class="event-info">
              <div class="event-title">${ev.title}</div>
              <div class="event-desc">${ev.desc}</div>
            </div>
            <span class="event-tag ${ev.tag}">${ev.tag}</span>
          </div>
        `).join('')}
      </div>
    </div>

    <div>
      <div class="mini-cal fade-up">
        <div class="cal-header">
          <div class="cal-month">Abril 2025</div>
        </div>
        <div class="cal-grid">
          ${['D','L','M','M','J','V','S'].map(d=>`<div class="cal-dow">${d}</div>`).join('')}
          ${buildCalendar(2025, 3)}
        </div>
      </div>

      <div class="panel fade-up" style="margin-top:14px;">
        <div class="panel-header"><div class="panel-title">🏷 Referencias</div></div>
        <div class="panel-body" style="padding:12px 18px;">
          <div style="display:flex;flex-direction:column;gap:8px;">
            ${[
              {tag:'examen',  label:'Examen / Evaluación'},
              {tag:'entrega', label:'Entrega'},
              {tag:'reunion', label:'Reunión'},
              {tag:'cultural',label:'Evento Cultural'},
              {tag:'ensayo',  label:'Ensayo / Práctica'}
            ].map(r=>`
              <div style="display:flex;align-items:center;gap:8px;">
                <span class="event-tag ${r.tag}">${r.tag}</span>
                <span style="font-size:12px;color:var(--muted)">${r.label}</span>
              </div>
            `).join('')}
          </div>
        </div>
      </div>
    </div>
  </div>`;
}

function buildCalendar(year, month){
  const days = new Date(year, month+1, 0).getDate();
  const firstDay = new Date(year, month, 1).getDay();
  const eventDays = new Set(data[grado].eventos.map(e=>e.day));
  const today = new Date().getDate();
  const todayMonth = new Date().getMonth();
  let html = '';
  for(let i=0;i<firstDay;i++) html += `<div class="cal-day other"></div>`;
  for(let d=1;d<=days;d++){
    const isToday = (d===today && todayMonth===month);
    const hasEv = eventDays.has(d);
    html += `<div class="cal-day ${isToday?'today':''} ${hasEv?'has-event':''}" title="${hasEv?'Evento programado':''}">${d}</div>`;
  }
  return html;
}

function openAddEvento(){
  document.getElementById('modalTitle').textContent = '📅 Nuevo Evento';
  document.getElementById('modalBody').innerHTML = `
    <div class="form-group">
      <label class="form-label">Título del evento</label>
      <input type="text" class="form-input" id="evTitle" placeholder="Ej: Feria de Ciencias">
    </div>
    <div class="form-group">
      <label class="form-label">Descripción</label>
      <input type="text" class="form-input" id="evDesc" placeholder="Ej: Patio principal – 10AM">
    </div>
    <div class="form-group" style="display:flex;gap:12px;">
      <div style="flex:1;">
        <label class="form-label">Día</label>
        <input type="number" class="form-input" id="evDay" placeholder="22" min="1" max="31">
      </div>
      <div style="flex:1;">
        <label class="form-label">Mes</label>
        <input type="text" class="form-input" id="evMon" placeholder="ABR" maxlength="3">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Tipo</label>
      <select class="form-select" id="evTag">
        <option value="examen">Examen</option>
        <option value="entrega">Entrega</option>
        <option value="reunion">Reunión</option>
        <option value="cultural">Cultural</option>
        <option value="ensayo">Ensayo</option>
      </select>
    </div>
  `;
  document.getElementById('modalConfirm').onclick = addEvento;
  document.getElementById('modal').classList.add('open');
}

function addEvento(){
  const title = document.getElementById('evTitle').value.trim();
  const desc  = document.getElementById('evDesc').value.trim()||'Sin descripción';
  const day   = parseInt(document.getElementById('evDay').value)||1;
  const mon   = (document.getElementById('evMon').value.trim()||'ABR').toUpperCase();
  const tag   = document.getElementById('evTag').value;
  if(!title){ toast('⚠ Ingresa el título del evento', 'warn'); return; }
  data[grado].eventos.push({day, mon, title, desc, tag});
  data[grado].eventos.sort((a,b)=>a.day-b.day);
  saveState();
  closeModal();
  toast('✅ Evento agregado', 'success');
  renderEventos(document.getElementById('contentArea'));
}

/* ===================================================
   SEARCH
=================================================== */
function buscar(q){
  if(currentSec === 'boletines'){
    renderBoletines(document.getElementById('contentArea'), filterLevel, q);
  }
}

/* ===================================================
   MODAL
=================================================== */
function closeModal(){
  document.getElementById('modal').classList.remove('open');
}

document.getElementById('modal').addEventListener('click', function(e){
  if(e.target === this) closeModal();
});

/* ===================================================
   TOAST
=================================================== */
function toast(msg, type='info'){
  const wrap = document.getElementById('toastWrap');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.textContent = msg;
  wrap.appendChild(el);
  setTimeout(()=>el.remove(), 3500);
}

/* ===================================================
   LOGOUT
=================================================== */
function salir(){
  toast('👋 Sesión cerrada', 'info');
  setTimeout(()=>{ window.location.href='index.html'; }, 1200);
}

/* ===================================================
   INIT
=================================================== */
render('inicio');
</script>
