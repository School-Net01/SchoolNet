          <th onclick="sortBy('prom')">Promedio <span class="sort-icon ${sortCol==='prom'?'sorted':''}">⇅</span></th>
          <th>Nivel</th>
        </tr>
      </thead>
      <tbody>
        ${lista.map((e,i)=>{
          const p = prom(e);
          const cls = notaClass(p);
          const idx = data[grado].estudiantes.indexOf(e);
